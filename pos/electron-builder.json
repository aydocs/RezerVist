{
    "appId": "com.RezerVist.pos",
    "productName": "RezerVist POS",
    "copyright": "Copyright © 2026 RezerVist",
    "directories": {
        "output": "release"
    },
    "files": [
        "dist/**/*",
        "dist-electron/**/*"
    ],
    "win": {
        "target": [
            {
                "target": "nsis",
                "arch": [
                    "x64"
                ]
            }
        ]
    },
    "nsis": {
        "oneClick": false,
        "perMachine": false,
        "allowToChangeInstallationDirectory": true,
        "deleteAppDataOnUninstall": true,
        "createDesktopShortcut": true,
        "createStartMenuShortcut": true,
        "shortcutName": "RezerVist",
        "runAfterFinish": true
    },
    "publish": [
        {
            "provider": "generic",
            "url": "https://api.RezerVist.com/updates/"
        }
    ]
}